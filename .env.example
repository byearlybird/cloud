# Shared (loaded in all environments)
# .env
PORT=3000

# Development (.env.development)
DATABASE_URL=file:./database.db
DATABASE_AUTH_TOKEN=
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

